# Forms - CRITICAL GUIDELINES

## ⚠️ IMPORTANT: Library Requirements

**Use Formik + Yup ONLY. Do NOT use react-hook-form, zod, or other form libraries.**

## Form State Management

- Use **Formik** for ALL form state management
- Use **Yup** for ALL validation schemas
- Keep form components client-only and scoped (wrap just the form subtree in `"use client"`)

## Validation

- Define Yup schemas in `/features/<feature>/schemas/`
- Pass schema via `validationSchema` prop in Formik
- Enable `validateOnBlur: true`, `validateOnChange: false`
- Show errors below each field using shadcn/ui error styles
- Schema files end with `.schema.ts`

## Form Components

- Form components end with `Form` (e.g., `SignInForm`, `ProfileForm`)
- Always connect `<Label>` with inputs via `htmlFor`
- Use shadcn/ui primitives (Input, Select, Checkbox, etc.) with Formik field wrappers
- Disable submit button while submitting; show pending state

## Complete Example

```tsx
"use client";

import { Formik, Form, Field } from 'formik';
import * as Yup from 'yup';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

// Define schema in separate file: /features/auth/schemas/sign-in.schema.ts
const signInSchema = Yup.object({
  email: Yup.string().email('Invalid email').required('Required'),
  password: Yup.string().min(8, 'Too short').required('Required'),
});

export function SignInForm(): JSX.Element {
  return (
    <Formik
      initialValues={{ email: '', password: '' }}
      validationSchema={signInSchema}
      validateOnBlur={true}
      validateOnChange={false}
      onSubmit={async (values) => {
        // handle submission
      }}
    >
      {({ errors, touched, isSubmitting }) => (
        <Form>
          <div>
            <Label htmlFor="email">Email</Label>
            <Field as={Input} id="email" name="email" type="email" />
            {errors.email && touched.email && (
              <p className="text-sm text-destructive">{errors.email}</p>
            )}
          </div>

          <div>
            <Label htmlFor="password">Password</Label>
            <Field as={Input} id="password" name="password" type="password" />
            {errors.password && touched.password && (
              <p className="text-sm text-destructive">{errors.password}</p>
            )}
          </div>

          <Button type="submit" disabled={isSubmitting}>
            {isSubmitting ? 'Signing in...' : 'Sign In'}
          </Button>
        </Form>
      )}
    </Formik>
  );
}
```

## Schema Example

```typescript
// /features/auth/schemas/sign-in.schema.ts
import * as Yup from 'yup';

export const signInSchema = Yup.object({
  email: Yup.string()
    .email('Please enter a valid email')
    .required('Email is required'),
  password: Yup.string()
    .min(8, 'Password must be at least 8 characters')
    .required('Password is required'),
});

export type SignInFormValues = Yup.InferType<typeof signInSchema>;
```

## Custom Field Components

```tsx
import { useField } from 'formik';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';

interface FormFieldProps {
  name: string;
  label: string;
  type?: string;
}

export function FormField({ name, label, type = 'text' }: FormFieldProps): JSX.Element {
  const [field, meta] = useField(name);
  const hasError = meta.touched && meta.error;

  return (
    <div>
      <Label htmlFor={name}>{label}</Label>
      <Input id={name} type={type} {...field} />
      {hasError && <p className="text-sm text-destructive">{meta.error}</p>}
    </div>
  );
}
```
