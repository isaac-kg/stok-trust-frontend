# Testing with Playwright

## Overview

- Use **Playwright** for all E2E tests; unit tests are optional
- Keep tests under `tests/` with `*.spec.ts` extension
- Do NOT add axios or custom fetch wrappers for tests
- Every user-facing route must have at least one smoke test

## Test Organization

```
/tests
├── fixtures/              - Shared fixtures
├── selectors/            - Central testids/selectors (if needed)
├── utils/
│   ├── auth.ts          - Auth helper functions
│   └── wait.ts          - Custom wait helpers
└── *.spec.ts            - Test files
```

## Locator Strategy

### Prefer Semantic Locators (in order of preference)

1. `getByRole` - Most semantic and accessible
2. `getByLabel` - For form inputs
3. `getByPlaceholder` - For inputs without labels
4. `getByText` - For buttons and links
5. `data-testid` - Only as last resort (use kebab-case)

```typescript
// Good - semantic locators
await page.getByRole('button', { name: /sign in/i }).click();
await page.getByLabel(/email/i).fill('user@example.com');
await page.getByPlaceholder(/search/i).fill('query');

// Acceptable - when semantic locators aren't available
await page.getByTestId('user-dropdown').click();

// Bad - brittle selectors
await page.locator('.btn-primary').click(); // CSS class
await page.locator('#submit-btn').click();  // ID selector
```

## Smoke Tests

Every user-facing route needs at least one smoke test:

```typescript
// tests/home.spec.ts
import { test, expect } from '@playwright/test';

test('home renders and navigates', async ({ page }) => {
  await page.goto('/');
  
  // Has unique title
  await expect(page).toHaveTitle(/.+/);
  
  // Has main landmark
  await expect(page.getByRole('main')).toBeVisible();
  
  // Navigation works
  await page.getByRole('link', { name: /get started/i }).click();
  await expect(page).toHaveURL(/getting-started/);
});
```

## Helper Functions

Create reusable helpers for common flows:

```typescript
// tests/utils/auth.ts
import type { Page } from '@playwright/test';

export interface SignInInput { 
  email: string; 
  password: string; 
}

export async function signIn(
  page: Page, 
  { email, password }: SignInInput
): Promise<void> {
  await page.goto('/login');
  await page.getByLabel(/email/i).fill(email);
  await page.getByLabel(/password/i).fill(password);
  await page.getByRole('button', { name: /sign in/i }).click();
  await page.waitForURL('/dashboard');
}
```

## Waiting Strategies

Avoid `page.waitForTimeout`. Use condition-based waits:

```typescript
// Good - wait for conditions
await page.waitForURL('/dashboard');
await page.getByRole('button', { name: /submit/i }).isVisible();
await page.waitForLoadState('networkidle');

// Bad - fixed timeouts
await page.waitForTimeout(3000);
```

## Playwright Config

```typescript
// playwright.config.ts
import { defineConfig, devices } from '@playwright/test';

export default defineConfig({
  testDir: './tests',
  fullyParallel: true,
  reporter: [['list'], ['html', { open: 'never' }]],
  use: {
    baseURL: process.env.PLAYWRIGHT_BASE_URL ?? 'http://localhost:3000',
    trace: 'on-first-retry',
  },
  webServer: {
    command: 'npm run dev',
    url: 'http://localhost:3000',
    reuseExistingServer: !process.env.CI,
    timeout: 120_000,
  },
  projects: [
    { name: 'chromium', use: { ...devices['Desktop Chrome'] } },
    { name: 'firefox',  use: { ...devices['Desktop Firefox'] } },
    { name: 'webkit',   use: { ...devices['Desktop Safari'] } },
  ],
});
```

